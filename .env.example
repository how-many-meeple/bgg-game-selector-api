# BGG API Configuration
# REQUIRED: Obtain from BoardGameGeek API registration
# Leave empty if awaiting approval (app will start but BGG calls will fail)
BGG_ACCESS_TOKEN=

BGG_TIMEOUT=60
BGG_RETRY_DELAY=10
BGG_RETRIES=6

# Cache Configuration
REQUEST_CACHE_DURATION=86400  # 1 day in seconds (collections, searches)
GAME_CACHE_DURATION=604800  # 1 week in seconds (individual game data)

# Cache Backend: 'dynamodb' (AWS) or 'memory' (local dev, lost on restart)
CACHE_BACKEND=dynamodb

# DynamoDB Configuration (for production)
DYNAMODB_REQUEST_TABLE=bgg-request-cache
DYNAMODB_GAME_TABLE=bgg-game-cache
AWS_REGION=us-east-1

# AWS Credentials (if not using IAM roles)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# Flask Configuration
FLASK_ENV=production

# CORS Configuration (for local development)
# In production, this is set via SAM template parameter
# For local dev: ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
ALLOWED_ORIGINS=*
